# ── Credentials ───────────────────────────────────────────────────────────────
# HuggingFace token to download Llama-3-8B-Instruct (requires licence acceptance)
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Gemini API key for LLM-as-judge quality evaluation
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Engine Endpoints ──────────────────────────────────────────────────────────
# These are set automatically by docker-compose; override for external servers.
VLLM_BASE_URL=http://localhost:8000
LLAMACPP_BASE_URL=http://localhost:8080

# ── Prometheus / Grafana ──────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# ── Model Configuration ───────────────────────────────────────────────────────
# Model name as reported by the serving engine's /v1/models endpoint
VLLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
LLAMACPP_MODEL_NAME=llama-3-8b-instruct

# ── Cost Model (Cloud GPU $/hr) ───────────────────────────────────────────────
# Adjust to your infrastructure. Used by cost_calculator.py.
# Examples: A100_40GB=3.00, RTX_3090=0.80, RTX_4090=1.20
GPU_COST_PER_HOUR=3.00
GPU_INSTANCE_LABEL=A100-40GB

# ── Judge Model ────────────────────────────────────────────────────────────────
GEMINI_JUDGE_MODEL=gemini-1.5-flash

# ── Results Output Directory ──────────────────────────────────────────────────
RESULTS_DIR=results
